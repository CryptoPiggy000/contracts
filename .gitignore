# Compiler files
cache/
out/

# Commonly ignored directories
.logs/
.ignore/

# Ignores development broadcast logs
!/broadcast
/broadcast/*/31337/
/broadcast/**/dry-run/

# Docs — ignore generated `forge doc` output, but keep hand-written runbooks.
docs/*
!docs/GUARDED_ROLLOUT.md
!docs/SECURITY_REVIEW.md

# Dotenv file
.env
.env.*
!.env.example
