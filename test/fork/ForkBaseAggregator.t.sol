pragma solidity ^0.8.28;

import {Test, console} from "forge-std/Test.sol";
import {IERC20} from "@openzeppelin/contracts/token/ERC20/IERC20.sol";

import {ProtocolRegistry} from "../../src/ProtocolRegistry.sol";
import {SmartInvestmentAccount} from "../../src/SmartInvestmentAccount.sol";
import {AccountFactory} from "../../src/AccountFactory.sol";
import {PositionClass, Action, ActionKind} from "../../src/Types.sol";

/// @title ForkBaseAggregator
/// @notice Proves a REAL DEX-aggregator swap (0x AllowanceHolder) executes through our account on live
///         Base — i.e. the opaque `routeData` from the backend's /market/quote flows through `_swap`
///         (approve-exact → router.call → balance-delta ≥ minOut) and delivers the bought token.
/// @dev    The quote is a pinned snapshot (calldata is taker- and block-specific). To refresh it:
///           1. `test_log_account` prints the deterministic account address (the 0x `taker`).
///           2. GET https://api.0x.org/swap/allowance-holder/quote?chainId=8453&sellToken=<USDC>&
///              buyToken=<WETH>&sellAmount=1000000000&taker=<account>&slippageBps=100
///              (headers: 0x-api-key, 0x-version: v2)
///           3. paste blockNumber → FORK_BLOCK, minBuyAmount → MIN_WETH, transaction.data → ZEROX_DATA.
///         Run: BASE_RPC_URL=https://mainnet.base.org forge test --match-path "test/fork/ForkBaseAggregator*" -vv
contract ForkBaseAggregator is Test {
    address constant USDC = 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913;
    address constant WETH = 0x4200000000000000000000000000000000000006;
    address constant ZEROX_ALLOWANCE_HOLDER = 0x0000000000001fF3684f28c67538d4D072C22734; // 0x v2 AllowanceHolder

    // --- pinned 0x quote (USDC→WETH, 1000 USDC, taker = the account below). Refresh per the header. ---
    uint256 constant FORK_BLOCK = 48_872_370; // pinned to the quote's block
    uint256 constant SELL_USDC = 1_000e6;
    uint256 constant MIN_WETH = 530696414044704600; // 0x minBuyAmount (~0.5307 WETH @ 1% slippage)
    bytes constant ZEROX_DATA =
        hex""; // 0x AllowanceHolder calldata (pinned snapshot)

    ProtocolRegistry registry;
    AccountFactory factory;
    SmartInvestmentAccount account;
    address owner = makeAddr("aggOwner");

    function setUp() public {
        string memory rpc = vm.envOr("BASE_RPC_URL", string(""));
        if (bytes(rpc).length == 0) return; // no RPC -> skip
        if (FORK_BLOCK == 0) vm.createSelectFork(rpc); // latest — for the log run
        else vm.createSelectFork(rpc, FORK_BLOCK); // pinned — so the snapshot calldata reproduces

        registry = new ProtocolRegistry(address(this));
        SmartInvestmentAccount impl = new SmartInvestmentAccount();
        factory = new AccountFactory(address(impl), address(registry));
        registry.addAsset(WETH, PositionClass.HELD_ASSET);
        registry.setRoute(ZEROX_ALLOWANCE_HOLDER, true);

        vm.prank(owner);
        account = SmartInvestmentAccount(factory.createAccount(bytes32(uint256(1))));
    }

    modifier onFork() {
        if (address(factory) == address(0)) {
            vm.skip(true);
            return;
        }
        _;
    }

    /// Run this once (no pinned quote needed) to get the deterministic account address for the 0x `taker`.
    function test_log_account() public onFork {
        console.log("ACCOUNT (use as 0x taker):", address(account));
    }

    /// Real 0x aggregator swap USDC→WETH through the account, using the pinned quote calldata.
    function test_base_0x_swap_through_account() public onFork {
        if (ZEROX_DATA.length == 0) {
            vm.skip(true); // no pinned quote yet — see the header
            return;
        }
        deal(USDC, address(account), SELL_USDC);

        Action memory swap;
        swap.kind = ActionKind.SWAP;
        swap.assetIn = USDC;
        swap.assetOut = WETH;
        swap.router = ZEROX_ALLOWANCE_HOLDER;
        swap.amount = SELL_USDC;
        swap.minOut = MIN_WETH;
        swap.routeData = ZEROX_DATA;

        Action[] memory plan = new Action[](1);
        plan[0] = swap;
        vm.prank(owner);
        account.executePlan(plan);

        assertGe(IERC20(WETH).balanceOf(address(account)), MIN_WETH, "0x aggregator delivered WETH >= minOut");
        assertEq(IERC20(USDC).balanceOf(address(account)), 0, "USDC fully spent");
    }
}
